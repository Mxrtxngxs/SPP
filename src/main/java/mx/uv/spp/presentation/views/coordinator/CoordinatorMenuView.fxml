<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.CoordinatorMenuController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Menu del Coordinador" />

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Gestión de Proyectos:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnRegisterProject" onAction="#registerProjectAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Registrar Proyecto" />
            <Button fx:id="btnAssignProject" onAction="#assignProjectAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Asignar Proyecto" />
        </HBox>
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnUpdateProject" onAction="#updateProjectAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #42ABFB; -fx-text-fill: white;" text="Actualizar Proyecto" />
            <Button fx:id="btnDeleteProject" onAction="#deleteProjectAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Eliminar Proyecto" />
        </HBox>
    </VBox>

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Gestion de Practicantes y Reportes:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnRegisterIntern" onAction="#registerInternAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Registrar Practicante" />
            <Button fx:id="btnInactivateIntern" onAction="#inactivateInternAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Inactivar Practicante" />
        </HBox>
        <Button fx:id="btnGenerateReport" onAction="#generateReportAction" prefHeight="40.0" prefWidth="375.0" style="-fx-background-color: #005BAA; -fx-text-fill: white;" text="Generar Reporte de Indicadores" />
    </VBox>

    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
        <Button fx:id="btnLogout" onAction="#logoutAction" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Cerrar Sesion" />
    </HBox>
</VBox>