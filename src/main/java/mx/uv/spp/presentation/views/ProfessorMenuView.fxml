<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.ProfessorMenuController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="lblWelcome" style="-fx-font-size: 13px; -fx-text-fill: #555;" text="Bienvenido, Profesor" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblCurrentUser" style="-fx-font-size: 13px; -fx-text-fill: #114B5F; -fx-font-weight: bold;" text="" />
    </HBox>

    <Separator />

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Menu del Profesor" />

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Gestion de Actividades y Formatos:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnGenerateActivity" onAction="#generateActivityAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Generar Actividad" />
            <Button fx:id="btnAddFormat" onAction="#addFormatAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Anadir Formato" />
        </HBox>
    </VBox>

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Evaluacion de Reportes:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnEvaluatePartialReport" onAction="#evaluatePartialReportAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #005BAA; -fx-text-fill: white;" text="Evaluar Reporte Parcial" />
            <Button fx:id="btnEvaluateMonthlyReport" onAction="#evaluateMonthlyReportAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #005BAA; -fx-text-fill: white;" text="Evaluar Reporte Mensual" />
        </HBox>
    </VBox>

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Consultas:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnListPractitioners"  prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #42A8FB; -fx-text-fill: white;" text="Ver Practicantes" />
            <Button fx:id="btnListActivities"  prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #42A8FB; -fx-text-fill: white;" text="Ver Actividades" />
        </HBox>
    </VBox>

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Comunicacion:" />
        <Button fx:id="btnMessages" onAction="#messagesAction" prefHeight="40.0" prefWidth="375.0" style="-fx-background-color: #00AB4F; -fx-text-fill: white;" text="Consultar Buzon de Mensajes" />
    </VBox>

    <Separator />

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnLogout" onAction="#logoutAction" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Cerrar Sesion" />
    </HBox>

</VBox>