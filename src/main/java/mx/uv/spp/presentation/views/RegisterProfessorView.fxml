<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.RegisterProfessorController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Registrar Profesor" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="15" alignment="CENTER">
        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtName" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Numero de personal:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtStaffNumber" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Contraseña:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <PasswordField fx:id="txtPassword" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Turno:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="cbShift" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="Seleccione un turno"/>
    </GridPane>

    <HBox alignment="CENTER" spacing="20.0">
        <Button text="Registrar" onAction="#registerProfessor"/>
        <Button text="Cancelar" onAction="#cancelAction"/>
    </HBox>
</VBox>