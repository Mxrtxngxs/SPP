<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.RegisterProfessorController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Registrar Profesor" />

    <GridPane alignment="CENTER" hgap="10" vgap="15">
        <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>

        <Label style="-fx-font-weight: bold;" text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtName" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label style="-fx-font-weight: bold;" text="Numero de personal:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtStaffNumber" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label style="-fx-font-weight: bold;" text="Contraseña:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <PasswordField fx:id="txtPassword" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label style="-fx-font-weight: bold;" text="Turno:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <ComboBox fx:id="cbShift" prefWidth="250.0" promptText="Seleccione un turno" GridPane.columnIndex="1" GridPane.rowIndex="3" />
    </GridPane>

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnCancel" onAction="#cancelAction" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Cancelar" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnRegister" onAction="#registerProfessor" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Registrar" />
    </HBox>

</VBox>
