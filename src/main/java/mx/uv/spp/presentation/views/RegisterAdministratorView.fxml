<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.RegisterAdministratorController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
   <VBox prefHeight="24.0" prefWidth="227.0">
      <children>
         <Button onAction="#returnMenu" mnemonicParsing="false" prefHeight="26.0" prefWidth="43.0" text="🡨" />
      </children>
   </VBox>

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Registrar Administrador" />

    <VBox spacing="5.0">
        <Label text="Nombre de usuario:" />
        <TextField fx:id="txtName" promptText="Ingrese el nombre de usuario" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Contraseña:" />
        <PasswordField fx:id="txtPassword" promptText="Minimo 10 caracteres (Mayusculas, minuscuas y numeros)" />
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
        <Button onAction="#cancelAction" text="Cancelar" />
        <Button onAction="#registerAdmin" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Registrar" />
    </HBox>
</VBox>
