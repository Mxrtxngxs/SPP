<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.MenuController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="Menu de Pruebas" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <Button text="Probar Login" onAction="#openLogin" prefWidth="250.0"/>
    <Button text="Probar Registrar Coordinador" onAction="#openRegisterCoordinator" prefWidth="250.0"/>
    <Button text="Probar Registrar Profesor" onAction="#openRegisterProfessor" prefWidth="250.0"/>
    <Button text="Probar Lista de Coordinadores" onAction="#openListCoordinators" prefWidth="250.0"/>
</VBox>