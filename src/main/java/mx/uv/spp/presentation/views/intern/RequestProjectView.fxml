<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Solicitar Proyecto" />

    <Label style="-fx-text-fill: #555;" text="Selecciona hasta 3 proyectos de tu preferencia." />

    <Label fx:id="lblCounter" style="-fx-font-weight: bold; -fx-text-fill: #114B5F;" text="Proyectos seleccionados: 0 / 3" />

    <TableView fx:id="tvProjects" prefHeight="300.0" prefWidth="650.0">
        <columns>
            <TableColumn fx:id="colName" prefWidth="200.0" text="Nombre del Proyecto" />
            <TableColumn fx:id="colCompany" prefWidth="180.0" text="Empresa" />
            <TableColumn fx:id="colCapacity" prefWidth="100.0" text="Cupo disponible" />
            <TableColumn fx:id="colStatus" prefWidth="160.0" text="Estado" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnCancel" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Cancelar" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnView" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #42A8FB; -fx-text-fill: white;" text="Visualizar" />
        <Region prefWidth="10.0" />
        <Button fx:id="btnSelect" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Seleccionar" />
    </HBox>

</VBox>