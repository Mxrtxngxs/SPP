<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Lista de Practicantes" />

    <TableView fx:id="tvPractitioners" prefHeight="300.0" prefWidth="700.0">
        <columns>
            <TableColumn fx:id="colName" prefWidth="220.0" text="Nombre" />
            <TableColumn fx:id="colMatricula" prefWidth="120.0" text="Matricula" />
            <TableColumn fx:id="colProject" prefWidth="180.0" text="Proyecto asignado" />
            <TableColumn fx:id="colProfessor" prefWidth="170.0" text="Profesor" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnBack" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Regresar" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnAssign" prefHeight="35.0" prefWidth="160.0" style="-fx-background-color: #005BAA; -fx-text-fill: white;" text="Asignar Proyecto" />
        <Region prefWidth="10.0" />
        <Button fx:id="btnDeactivate" prefHeight="35.0" prefWidth="180.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Inactivar Seleccionado" />
    </HBox>

</VBox>