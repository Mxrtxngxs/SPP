<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.AdminMenuController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="lblWelcome" style="-fx-font-size: 13px; -fx-text-fill: #555;" text="Bienvenido Administrador" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblCurrentUser" style="-fx-font-size: 13px; -fx-text-fill: #114B5F; -fx-font-weight: bold;" text="" />
    </HBox>

    <Separator />

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Menu del Administrador" />

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Gestion de Cuentas Activas:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnRegisterCoordinator" onAction="#registerCoordinatorAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Registrar Coordinador" />
            <Button fx:id="btnRegisterProfessor" onAction="#registerProfessorAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Registrar Profesor" />
        </HBox>
    </VBox>

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Gestion de Bajas:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnInactivateCoordinator" onAction="#inactivateCoordinatorAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Inactivar Coordinador" />
            <Button fx:id="btnInactivateProfessor" onAction="#inactivateProfessorAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Inactivar Profesor" />
        </HBox>
    </VBox>

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Consultas:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnListCoordinators" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #42A8FB; -fx-text-fill: white;" text="Ver Coordinadores" />
            <Button fx:id="btnListProfessors" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #42A8FB; -fx-text-fill: white;" text="Ver Profesores" />
        </HBox>
    </VBox>

    <Separator />

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnLogout" onAction="#logoutAction" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Cerrar Sesión" />
    </HBox>

</VBox>
