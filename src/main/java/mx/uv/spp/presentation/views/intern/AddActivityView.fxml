<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Anadir Actividad" />

    <Label style="-fx-text-fill: #555;" text="Sube el archivo de la actividad indicada por el Profesor." />

    <VBox alignment="CENTER" spacing="10.0" style="-fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 20;">
        <Label fx:id="lblFileName" style="-fx-text-fill: #777;" text="Ningun archivo seleccionado" />
        <Button fx:id="btnSelect" prefHeight="35.0" prefWidth="180.0" style="-fx-background-color: #42A8FB; -fx-text-fill: white;" text="Seleccionar archivo" />
    </VBox>

    <VBox fx:id="vboxPreview" alignment="CENTER" spacing="5.0" visible="false">
        <Label style="-fx-font-weight: bold;" text="Vista previa:" />
        <Label fx:id="lblPreview" style="-fx-text-fill: #555;" text="" />
    </VBox>

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnCancel" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Cancelar" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnConfirm" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Confirmar" />
    </HBox>

</VBox>