<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.DesactivateCoordinatorController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Inactivar Coordinador" />

    <GridPane hgap="10" vgap="15" alignment="CENTER">
        <Label text="Nombre:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="lblName" text="[Nombre del Coordinador]" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Numero de personal:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="lblPersonalNumber" text="[Numero de Personal]" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Estado Actual:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="lblState" text="Activo" textFill="GREEN" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnCancel" onAction="#cancelAction" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Cancelar" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnDeactivate" onAction="#desactivateCoordinator" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Inactivar" />
    </HBox>

</VBox>