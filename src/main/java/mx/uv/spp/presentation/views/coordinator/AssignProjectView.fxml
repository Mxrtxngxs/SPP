<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Asignar Proyecto" />

    <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Practicante seleccionado:" />

    <TableView fx:id="tvPractitioner" prefHeight="80.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="colPractitionerName" prefWidth="300.0" text="Nombre" />
            <TableColumn fx:id="colPractitionerMatricula" prefWidth="290.0" text="Matricula" />
        </columns>
    </TableView>

    <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Proyectos solicitados por el practicante:" />

    <TableView fx:id="tvProjects" prefHeight="200.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="colProjectName" prefWidth="200.0" text="Proyecto" />
            <TableColumn fx:id="colCompany" prefWidth="180.0" text="Empresa" />
            <TableColumn fx:id="colCapacity" prefWidth="100.0" text="Cupo disponible" />
            <TableColumn fx:id="colStatus" prefWidth="110.0" text="Estado" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnCancel" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Cancelar" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnAssign" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Asignar" />
    </HBox>

</VBox>