<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.InternMenuController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Menú del Practicante" />

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Proyectos:" />
        <Button fx:id="btnRequestProject" onAction="#requestProjectAction" prefHeight="40.0" prefWidth="375.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Solicitar Proyecto" />
    </VBox>

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Reportes y Actividades:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnPartialReports" onAction="#partialReportsAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #005BAA; -fx-text-fill: white;" text="Reportes Parciales" />
            <Button fx:id="btnMonthlyReports" onAction="#monthlyReportsAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #005BAA; -fx-text-fill: white;" text="Reportes Mensuales" />
        </HBox>
        <Button fx:id="btnAddActivity" onAction="#addActivityAction" prefHeight="40.0" prefWidth="375.0" style="-fx-background-color: #42ABFB; -fx-text-fill: white;" text="Subir Entrega de Actividad" />
    </VBox>

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold;" text="Documentación y Seguimiento:" />
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnAddSchedule" onAction="#addScheduleAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Añadir Horario" />
            <Button fx:id="btnPSPBitacora" onAction="#pspBitacoraAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Bitácora PSP" />
        </HBox>
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnActivityPlan" onAction="#activityPlanAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Plan de Actividades" />
            <Button fx:id="btnSelfEvaluation" onAction="#selfEvaluationAction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #114B5F; -fx-text-fill: white;" text="Autoevaluación" />
        </HBox>
    </VBox>

    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
        <Button fx:id="btnLogout" onAction="#logoutAction" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Cerrar Sesión" />
    </HBox>
</VBox>