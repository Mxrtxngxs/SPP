<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Inactivar Practicante" />

    <Label style="-fx-font-size: 13px; -fx-text-fill: #555555;" text="Seleccione el practicante que desea inactivar:" />

    <TableView fx:id="tblPractitioners" prefHeight="320.0" prefWidth="650.0">
        <columns>
            <TableColumn fx:id="colMatricula" prefWidth="130.0" text="Matricula" />
            <TableColumn fx:id="colName" prefWidth="250.0" text="Nombre" />
            <TableColumn fx:id="colProject" prefWidth="200.0" text="Proyecto asignado" />
            <TableColumn fx:id="colStatus" prefWidth="100.0" text="Estado" />
        </columns>
    </TableView>

    <Label fx:id="lblErrorMessage" style="-fx-text-fill: red;" text="" />

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="btnDeactivate" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Inactivar Practicante" />
        <Button fx:id="btnCancel" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #757575; -fx-text-fill: white;" text="Cancelar" />
    </HBox>
</VBox>
