<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.DesactivateProfessorController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Inactivar Profesor" />

    <Label style="-fx-font-size: 13px; -fx-text-fill: #555555;" text="Seleccione el Profesor que desea inactivar:" />

    <TableView fx:id="tblProfessors" prefHeight="300.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="colName" prefWidth="250.0" text="Nombre" />
            <TableColumn fx:id="colStaffNumber" prefWidth="180.0" text="Numero de personal" />
            <TableColumn fx:id="colShift" prefWidth="120.0" text="Turno" />
        </columns>
    </TableView>

    <Label fx:id="lblErrorMessage" style="-fx-text-fill: red;" text="" />

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="btnDeactivate" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" text="Inactivar Profesor" />
        <Button fx:id="btnCancel" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #757575; -fx-text-fill: white;" text="Cancelar" />
    </HBox>
</VBox>
