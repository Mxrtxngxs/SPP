<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.spp.presentation.controllers.DesactivateCoordinatorController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Inactivar Coordinador" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="15" alignment="CENTER">
        <Label text="Nombre:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="lblName" text="[Nombre del Coordinador]" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Numero de personal:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="lblPersonalNumber" text="[Numero de Personal]" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Estado Actual:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label text="Activo" textFill="GREEN" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="btnDeactivate" text="Inactivar" style="-fx-text-fill: red;" onAction="#desactivateCoordinator"/>
        <Button fx:id="btnCancel" text="Cancelar" onAction="#cancelAction"/>
    </HBox>
</VBox>